# AWS-s3 - storage

STORAGE_ACCESS_KEY_ID=your_storage_access_key_id
STORAGE_SECRET_ACCESS_KEY=your_storage_secret_access_key
STORAGE_BUCKET_NAME=your_storage_bucket_name
STORAGE_REGION=your_region


GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash


WHISPER_MODEL_SIZE=medium.en
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8


MIN_AUDIO_SECONDS=30
MAX_AUDIO_SECONDS=45

DATA_RETENTION_HOURS=48

FRONTEND_ORIGIN=http://localhost:5173
